      "dialog": {
        "start": {
          "text": "Psst... nicht so laut. Die Kaninchen mögen keine Fremden.",
          "choices": [
            {
              "text": "Wer bist du?",
              "next": "vorstellung"
            },
            {
              "text": "Warum lebst du hier unten?",
              "next": "story"
            },
            {
              "text": "Okay... ich geh wieder.",
              "next": null
            }
          ]
        },
        "vorstellung": {
          "text": "Ich bin Amina. Früher... naja, ich hatte größere Pläne.",
          "next": "story"
        },
        "story": {
          "text": "Ich wollte eine Wolke fangen. Einfach so, aus dem Himmel reißen.\nIch hatte sogar eine Harpune gebaut.\n\nHat nicht funktioniert.\nAlle haben gelacht.\n\nAlso bin ich hier runter. Die Kaninchen stellen keine Fragen.",
          "choices": [
            {
              "text": "Du lebst jetzt echt bei Kaninchen?",
              "next": "kaninchen"
            },
            {
              "text": "Und die Harpune?",
              "next": "harpune"
            },
            {
              "text": "Okay… viel Glück noch.",
              "next": null
            }
          ]
        },
        "kaninchen": {
          "text": "Die sind erstaunlich organisiert.\nAber ihre Höhlen sind hart wie Stein.\n\nIch hab seit Tagen nicht richtig geschlafen...",
          "next": "wunsch"
        },
        "harpune": {
          "text": "Die funktioniert theoretisch.\nPraktisch… naja.\nIch brauch sie hier unten eh nicht mehr.",
          "next": "wunsch"
        },
        "wunsch": {
          "text": "Wenn ich nur ein Kissen hätte...\nDann wäre das hier unten fast gemütlich.",
          "next": null
        },
        "tausch": {
          "text": "Ein Kissen...\nDas ist perfekt.\n\nHier. Nimm die Wolkenharpune.\nVielleicht klappt es ja bei dir besser als bei mir.",
          "trade": {
            "give": "kissen",
            "receive": "wolkenharpune"
          },
          "next": "nach_tausch"
        },
        "nach_tausch": {
          "text": "Jetzt ist es hier unten endlich weich.\n\nUnd du? Versuch nicht zu hoch zu zielen.",
          "next": null
        },
        "hat_kissen": {
          "text": "Du hast da ein Kissen...\nWillst du tauschen?",
          "next": null
        },
        "hat_schon_getauscht": {
          "text": "Die Harpune hast du ja schon.\n\nPass auf, dass du nicht auch unten landest wie ich.",
          "next": null
        },
        "falsch_item": {
          "text": "Das hilft mir hier unten nicht wirklich.",
          "next": null
        }
      }
    }
  }
